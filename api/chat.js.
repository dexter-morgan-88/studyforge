export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') { res.status(200).end(); return; }
  if (req.method !== 'POST') { res.status(405).json({ error: 'Method not allowed' }); return; }

  const KEY = process.env.CLAUDE_API_KEY;
  if (!KEY) { res.status(500).json({ error: 'CLAUDE_API_KEY not set in Vercel environment variables' }); return; }

  const { prompt, images } = req.body;
  if (!prompt) { res.status(400).json({ error: 'No prompt' }); return; }

  const content = [];
  if (images && Array.isArray(images)) {
    for (const img of images) {
      if (img.type === 'image' && img.data && img.media_type) {
        content.push({ type: 'image', source: { type: 'base64', media_type: img.media_type, data: img.data } });
      }
    }
  }
  content.push({ type: 'text', text: prompt });

  try {
    const r = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': KEY, 'anthropic-version': '2023-06-01' },
      body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 4096, messages: [{ role: 'user', content }] })
    });
    if (!r.ok) { const e = await r.json(); res.status(r.status).json({ error: e.error?.message || 'AI error' }); return; }
    const d = await r.json();
    res.status(200).json({ result: d.content[0].text });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
}
