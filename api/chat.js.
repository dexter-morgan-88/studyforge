export default async function handler(req, res) {
  // Allow requests from your site only
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') { res.status(200).end(); return; }
  if (req.method !== 'POST') { res.status(405).json({ error: 'Method not allowed' }); return; }
 
  // API key lives here on the server — users NEVER see this
  const CLAUDE_KEY = process.env.CLAUDE_API_KEY;
  if (!CLAUDE_KEY) { res.status(500).json({ error: 'Server not configured' }); return; }
 
  try {
    const { prompt, tool } = req.body;
    if (!prompt || !tool) { res.status(400).json({ error: 'Missing prompt or tool' }); return; }
 
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': CLAUDE_KEY,
        'anthropic-version': '2023-06-01'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 4000,
        messages: [{ role: 'user', content: prompt }]
      })
    });
 
    if (!response.ok) {
      const err = await response.json();
      res.status(response.status).json({ error: err.error?.message || 'AI error' });
      return;
    }
 
    const data = await response.json();
    res.status(200).json({ result: data.content[0].text });
 
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
}
