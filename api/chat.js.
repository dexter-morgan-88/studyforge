module.exports = async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');

  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'Use POST' });

  const KEY = process.env.CLAUDE_API_KEY;
  if (!KEY) return res.status(500).json({ error: 'CLAUDE_API_KEY not set in Vercel environment variables' });

  const { prompt, images } = req.body || {};
  if (!prompt) return res.status(400).json({ error: 'Missing prompt' });

  // Build content array — images first, then text
  const content = [];

  if (Array.isArray(images)) {
    for (const img of images) {
      if (!img || !img.data || !img.media_type) continue;
      let b64 = img.data;
      if (b64.includes(',')) b64 = b64.split(',')[1];
      if (!b64 || b64.length < 10) continue;
      const allowed = ['image/jpeg','image/png','image/gif','image/webp'];
      content.push({
        type: 'image',
        source: {
          type: 'base64',
          media_type: allowed.includes(img.media_type) ? img.media_type : 'image/jpeg',
          data: b64,
        },
      });
    }
  }

  content.push({ type: 'text', text: String(prompt).trim() });

  let raw;
  try {
    const r = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': KEY,
        'anthropic-version': '2023-06-01',
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 4096,
        messages: [{ role: 'user', content }],
      }),
    });

    const data = await r.json();

    if (!r.ok) {
      const msg = (data.error && data.error.message) || JSON.stringify(data);
      if (r.status === 401) return res.status(401).json({ error: 'Invalid API key: ' + msg });
      if (r.status === 429) return res.status(429).json({ error: 'Rate limited. Try again in a moment.' });
      return res.status(r.status).json({ error: 'Claude error: ' + msg });
    }

    raw = data?.content?.[0]?.text;
    if (!raw) return res.status(500).json({ error: 'Claude returned empty response' });

  } catch (e) {
    return res.status(502).json({ error: 'Network error: ' + e.message });
  }

  return res.status(200).json({ result: raw });
};
